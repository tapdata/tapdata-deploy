  log_step "Configure Lite mode parameters"

  prompt_input "MongoDB port mapping (host port)" "27006" MONGO_HOST_PORT
  prompt_input "TapData port mapping (host port)" "13030" TAPDATA_HOST_PORT
  
  # Select TapData image version
  prompt_image_tag "tapdata8/tapdata" "TAPDATA_TAG" 5
  TAPDATA_IMAGE="tapdata8/tapdata:${SELECTED_IMAGE_TAG}"
  
  prompt_input "MongoDB username" "root" TAP_DEPLOY_MONGO_USER
  prompt_input "MongoDB password" "" TAP_DEPLOY_MONGO_PASSWORD

  TAP_DEPLOY_MONGO_URI=""
  MONGODB_CONNECTION_STRING="mdb0:27017/tapdata?authSource=admin"
  TAP_DEPLOY_NAMESPACE="tapdata"
  TAP_DEPLOY_HELM_RELEASE="tapdata"
  TAP_DEPLOY_IMAGE_REGISTRY=""
  TAP_DEPLOY_STORAGE_PATH=""
}

_init_cloud() {
  log_step "Configure Cloud mode parameters"

  # Cloud provider
  prompt_select "Select cloud provider" "Huawei Cloud" "AWS"
  case "$SELECTED_OPTION" in
    Huawei*) TAP_DEPLOY_CLOUD_PROVIDER="huaweicloud" ;;
    AWS*)    TAP_DEPLOY_CLOUD_PROVIDER="aws" ;;
  esac

  echo ""
  prompt_input "Region" "$([ "$TAP_DEPLOY_CLOUD_PROVIDER" = "huaweicloud" ] && echo 'cn-north-4' || echo 'ap-southeast-1')" TAP_DEPLOY_CLOUD_REGION
  prompt_password "Access Key" TAP_DEPLOY_CLOUD_ACCESS_KEY
  prompt_password "Secret Key" TAP_DEPLOY_CLOUD_SECRET_KEY
  prompt_input "VPC CIDR" "172.16.0.0/16" TAP_DEPLOY_CLOUD_VPC_CIDR

  # Availability zones
  local default_azs
  if [ "$TAP_DEPLOY_CLOUD_PROVIDER" = "huaweicloud" ]; then
    default_azs="cn-north-4a,cn-north-4b"
  else
    default_azs="ap-southeast-1a,ap-southeast-1b"
  fi
  prompt_input "Availability zones (comma-separated)" "$default_azs" TAP_DEPLOY_CLOUD_AZS

  # Cluster config
  prompt_input "Cluster name" "tapdata-k8s" TAP_DEPLOY_CLOUD_CLUSTER_NAME
  prompt_input "Worker node count" "2" TAP_DEPLOY_CLOUD_NODE_COUNT

  if [ "$TAP_DEPLOY_CLOUD_PROVIDER" = "huaweicloud" ]; then
    prompt_input "Node flavor (flavor_id)" "s6.large.2" CLOUD_NODE_FLAVOR
    TAP_DEPLOY_CLOUD_NODE_FLAVOR="$CLOUD_NODE_FLAVOR"
  else
    prompt_input "Node instance type" "t3.medium" CLOUD_NODE_INSTANCE_TYPE
    TAP_DEPLOY_CLOUD_NODE_INSTANCE_TYPE="$CLOUD_NODE_INSTANCE_TYPE"
    prompt_input "K8s version" "1.29" CLOUD_CLUSTER_VERSION
    TAP_DEPLOY_CLOUD_CLUSTER_VERSION="$CLOUD_CLUSTER_VERSION"
  fi

  prompt_input "Key pair name (leave empty to auto-create)" "" TAP_DEPLOY_CLOUD_KEY_PAIR_NAME
  TAP_DEPLOY_CLOUD_NEW_CLUSTER="true"

  # MongoDB and TapData config
  echo ""
  prompt_input "MongoDB username" "root" TAP_DEPLOY_MONGO_USER
  prompt_input "MongoDB password" "AbcDef123" TAP_DEPLOY_MONGO_PASSWORD
  prompt_input "Helm release name" "tapdata" TAP_DEPLOY_HELM_RELEASE
  prompt_input "Namespace" "tapdata" TAP_DEPLOY_NAMESPACE
  
  # Select TapData image version
  echo ""
  prompt_image_tag "tapdata8/tapdata" "TAPDATA_TAG" 5
  TAP_DEPLOY_IMAGE_TAG="${SELECTED_IMAGE_TAG}"
  
  # Image registry is automatically configured from Terraform outputs during apply
  log_info "Image registry will be automatically configured from cloud provider after infrastructure creation"
}

_init_onprem() {
  log_step "Configure On-Prem mode parameters"

  # Online or offline
  if prompt_confirm "Is this an air-gapped/offline environment?" "n"; then
    TAP_DEPLOY_OFFLINE="true"
  else
    TAP_DEPLOY_OFFLINE="false"
  fi

  prompt_input "MongoDB username" "root" TAP_DEPLOY_MONGO_USER
  prompt_input "MongoDB password" "AbcDef123" TAP_DEPLOY_MONGO_PASSWORD
  prompt_input "Helm release name" "tapdata" TAP_DEPLOY_HELM_RELEASE
  prompt_input "Namespace" "tapdata" TAP_DEPLOY_NAMESPACE

  if [ "$TAP_DEPLOY_OFFLINE" = "true" ]; then
    prompt_input "Internal image registry URL (Harbor/SWR etc.)" "" TAP_DEPLOY_HARBOR_REGISTRY
    TAP_DEPLOY_IMAGE_REGISTRY="$TAP_DEPLOY_HARBOR_REGISTRY"
  else
    prompt_input "Image registry prefix (leave empty for Docker Hub)" "" TAP_DEPLOY_IMAGE_REGISTRY
  fi

  TAP_DEPLOY_CLOUD_KEY_PAIR_NAME=""
}

# Render configuration files based on mode
_render_configs() {
  local tmpl_dir

  # Render common application config
  tmpl_dir=$(get_template_dir "templates")

  # application.yml
  render_template "$tmpl_dir/application.yml.tmpl" "$WORK_DIR/application.yml"
  log_info "Generated: application.yml"

  # agent.yml
  render_template "$tmpl_dir/agent.yml.tmpl" "$WORK_DIR/agent.yml"
  log_info "Generated: agent.yml"

  case "$TAP_DEPLOY_MODE" in
    lite)
      _render_lite_configs
      ;;
    cloud)
      _render_cloud_configs
      ;;
    on-prem)
      _render_onprem_configs
      ;;
  esac
}

_render_lite_configs() {
  local tmpl_dir
  tmpl_dir=$(get_template_dir "deploy-on-docker")

  # Set template variables for Lite mode
  MONGO_HOST_PORT="${MONGO_HOST_PORT:-27006}"
  TAPDATA_HOST_PORT="${TAPDATA_HOST_PORT:-13030}"
  TAPDATA_IMAGE="${TAPDATA_IMAGE:-tapdata8/tapdata:latest}"
  TAPDATA_TAG="$(echo "$TAPDATA_IMAGE" | cut -d':' -f2)"
  MONGODB_USER="${TAP_DEPLOY_MONGO_USER:-root}"
  MONGODB_PASSWORD="${TAP_DEPLOY_MONGO_PASSWORD:-}"
