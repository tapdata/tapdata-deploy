_apply_onprem_offline() {
  log_step "On-Prem offline deployment"

  check_cmd docker

  local bundle_path="${TAP_DEPLOY_BUNDLE_PATH:-$WORK_DIR/images-bundle.tar.gz}"
  local registry="${TAP_DEPLOY_HARBOR_REGISTRY:-}"

  if [ -z "$registry" ]; then
    log_error "Offline deployment requires an internal image registry (TAP_DEPLOY_HARBOR_REGISTRY)"
  fi

  # Step 1: Load images
  log_step "Step 1: Load offline images"
  if [ -f "$bundle_path" ]; then
    docker load -i "$bundle_path"
  else
    log_error "Offline image bundle not found: $bundle_path"
  fi

  # Step 2: Tag and push images to internal registry
  log_step "Step 2: Push images to internal registry ($registry)"
  local images="tapdata8/tapdata:latest mongo:6.0 bitnami/kubectl:latest"
  for img in $images; do
    local target="$registry/$img"
    docker tag "$img" "$target"
    docker push "$target"
    log_info "Pushed: $target"
  done

  # Step 3: Install MongoDB Operator
  log_step "Step 3: Install MongoDB Community Operator"
  # In offline mode, the operator image should already be loaded
  # Use the offline chart if available
  local operator_chart="$WORK_DIR/charts/mongodb-community-operator"
  if [ -d "$operator_chart" ]; then
    helm install community-operator "$operator_chart" \
      --namespace mongodb \
      --create-namespace \
      --set operator.watchNamespace="*" \
      --set image.repository="$registry/mongodb/community-operator"
  else
    log_warn "MongoDB Operator offline chart not found, attempting online install"
    helm repo add mongodb https://mongodb.github.io/helm-charts
    helm install community-operator mongodb/community-operator \
      --namespace mongodb \
      --create-namespace \
      --set operator.watchNamespace="*"
  fi

  # Step 4: Deploy TapData
  log_step "Step 4: Deploy TapData (Helm)"
  _helm_install

  echo ""
  log_info "TapData On-Prem offline deployment initiated!"
  echo "  Check deployment status: bash tap-deploy status"
}

_helm_install() {
  local release="${TAP_DEPLOY_HELM_RELEASE:-tapdata}"
  local namespace="${TAP_DEPLOY_NAMESPACE:-tapdata}"
  local chart_dir

  # Find the Helm chart directory
  if [ -d "$WORK_DIR/deploy-on-kubernetes" ]; then
    chart_dir="$WORK_DIR/deploy-on-kubernetes"
  elif [ -d "$DEPLOY_HOME/deploy-on-kubernetes" ]; then
    chart_dir="$DEPLOY_HOME/deploy-on-kubernetes"
  else
    log_error "Helm chart directory not found: deploy-on-kubernetes"
  fi

  local values_file="$WORK_DIR/values.yaml"
  if [ ! -f "$values_file" ]; then
    log_error "values.yaml not found in $WORK_DIR. Run 'tap-deploy init' first."
  fi

  helm install "$release" "$chart_dir" \
    --namespace "$namespace" \
    --create-namespace \
    -f "$values_file"

  log_info "Waiting for pods to be ready..."
  kubectl wait --for=condition=ready pod -l app.kubernetes.io/instance="$release" -n "$namespace" --timeout=600s || true
}

# ============================================================================
# STATUS Command
# ============================================================================

cmd_status() {
  load_config

  log_step "Deployment status - Mode: $TAP_DEPLOY_MODE"
  echo ""

  case "$TAP_DEPLOY_MODE" in
    lite)
      _status_lite
      ;;
    cloud)
      _status_cloud
      ;;
    on-prem)
      _status_onprem
      ;;
  esac
}

_status_lite() {
  local compose_cmd
  if docker compose version &>/dev/null; then
    compose_cmd="docker compose"
  elif docker-compose version &>/dev/null 2>&1; then
    compose_cmd="docker-compose"
  else
    log_error "Docker Compose not found"
  fi

  if [ -f "$WORK_DIR/docker-compose.yaml" ]; then
    $compose_cmd -f "$WORK_DIR/docker-compose.yaml" ps
  else
    log_error "docker-compose.yaml not found in $WORK_DIR"
  fi
}

_status_cloud() {
  local release="${TAP_DEPLOY_HELM_RELEASE:-tapdata}"
  local namespace="${TAP_DEPLOY_NAMESPACE:-tapdata}"

  echo "--- Terraform State ---"
  local tf_dir="$WORK_DIR/infrastructure/${TAP_DEPLOY_CLOUD_PROVIDER:-huaweicloud}"
  if [ -d "$tf_dir" ]; then
    (cd "$tf_dir" && terraform show) || true
  else
    echo "  Terraform directory not found"
  fi

  echo ""
  echo "--- Helm Status ---"
  if has_cmd helm; then
    helm status "$release" -n "$namespace" 2>/dev/null || echo "  Helm release '$release' not found"
  else
    echo "  helm command not found"
  fi

  echo ""
  echo "--- Pod Status ---"
  if has_cmd kubectl; then
    kubectl get pods -n "$namespace" 2>/dev/null || echo "  Unable to get pod status"
  else
    echo "  kubectl command not found"
  fi
}

_status_onprem() {
  local release="${TAP_DEPLOY_HELM_RELEASE:-tapdata}"
  local namespace="${TAP_DEPLOY_NAMESPACE:-tapdata}"

  echo "--- Helm Status ---"
  if has_cmd helm; then
    helm status "$release" -n "$namespace" 2>/dev/null || echo "  Helm release '$release' not found"
  else
    echo "  helm command not found"
  fi

  echo ""
  echo "--- Pod Status ---"
  if has_cmd kubectl; then
    kubectl get pods -n "$namespace" 2>/dev/null || echo "  Unable to get pod status"
  else
    echo "  kubectl command not found"
  fi
}

# ============================================================================
# DESTROY Command
# ============================================================================

cmd_destroy() {
  load_config

  log_step "Destroy deployment - Mode: $TAP_DEPLOY_MODE"
  echo ""

  if ! prompt_confirm "Are you sure you want to destroy the TapData deployment? This action is irreversible" "n"; then
    log_info "Operation cancelled"
    return
  fi

  case "$TAP_DEPLOY_MODE" in
    lite)    _destroy_lite ;;
    cloud)   _destroy_cloud ;;
    on-prem) _destroy_onprem ;;
  esac
}

_destroy_lite() {
  local compose_cmd
  if docker compose version &>/dev/null; then
    compose_cmd="docker compose"
  elif docker-compose version &>/dev/null 2>&1; then
    compose_cmd="docker-compose"
  else
    log_error "Docker Compose not found"
  fi

  $compose_cmd -f "$WORK_DIR/docker-compose.yaml" down -v
  log_info "TapData Lite deployment destroyed"
}

_destroy_cloud() {
  local release="${TAP_DEPLOY_HELM_RELEASE:-tapdata}"
  local namespace="${TAP_DEPLOY_NAMESPACE:-tapdata}"

  # Uninstall Helm first
  log_step "Step 1: Uninstall TapData (Helm)"
  if has_cmd helm; then
    helm uninstall "$release" -n "$namespace" 2>/dev/null || true
  fi

  # Destroy Terraform infrastructure
  log_step "Step 2: Destroy infrastructure (Terraform)"
  local tf_dir="$WORK_DIR/infrastructure/${TAP_DEPLOY_CLOUD_PROVIDER:-huaweicloud}"
  if [ -d "$tf_dir" ]; then
    cd "$tf_dir"
    terraform destroy -var-file=terraform.tfvars -auto-approve
  else
    log_warn "Terraform directory not found, skipping infrastructure destroy"
  fi

  log_info "TapData Cloud deployment destroyed"
}

_destroy_onprem() {
  local release="${TAP_DEPLOY_HELM_RELEASE:-tapdata}"
  local namespace="${TAP_DEPLOY_NAMESPACE:-tapdata}"

  if has_cmd helm; then
    helm uninstall "$release" -n "$namespace"
  else
    log_error "helm command not found"
  fi

  log_info "TapData On-Prem deployment destroyed"
}

# ============================================================================
# BUNDLE Command
# ============================================================================

cmd_bundle() {
  local output="${1:-$WORK_DIR/images-bundle.tar.gz}"
  local arch_list=""

  check_cmd docker

  log_step "Create offline installation bundle"
  echo ""

  # Determine architecture
  prompt_select "Select target architecture" "AMD64" "ARM64" "Both (AMD64 + ARM64)"
  case "$SELECTED_OPTION" in
    AMD64)      arch_list="linux/amd64" ;;
    ARM64)      arch_list="linux/arm64" ;;
    Both*)      arch_list="linux/amd64,linux/arm64" ;;
  esac

  local tmp_dir
  tmp_dir=$(mktemp -d)
  local bundle_dir="$tmp_dir/tapdata-bundle"
  mkdir -p "$bundle_dir/images" "$bundle_dir/chart" "$bundle_dir/config"

  # List of images to bundle
  local images=(
    "tapdata8/tapdata:latest"
    "mongo:6.0"
    "mongodb/community-operator:latest"
    "bitnami/kubectl:latest"
  )

  # Pull and save images
  log_step "Pull container images"
  for arch in ${arch_list//,/ }; do
    for img in "${images[@]}"; do
      log_info "Pulling: $img ($arch)"
      if [ "$arch" = "linux/amd64" ]; then
        docker pull --platform linux/amd64 "$img" || docker pull "$img"
      else
        docker pull --platform "$arch" "$img" || log_warn "Failed to pull $img for $arch, skipping"
      fi
    done
  done

  # Save images to tar
  log_step "Package container images"
  docker save -o "$bundle_dir/images/images.tar" "${images[@]}" 2>/dev/null || {
    # Fallback: save one by one
    for img in "${images[@]}"; do
      local img_name
      img_name=$(echo "$img" | tr '/:' '_')
      docker save -o "$bundle_dir/images/${img_name}.tar" "$img"
    done
  }

  # Copy Helm chart
  log_step "Package Helm Chart"
  local chart_src
  if [ -d "$DEPLOY_HOME/deploy-on-kubernetes" ]; then
    chart_src="$DEPLOY_HOME/deploy-on-kubernetes"
  elif [ -d "$WORK_DIR/deploy-on-kubernetes" ]; then
    chart_src="$WORK_DIR/deploy-on-kubernetes"
  else
    log_error "Helm chart directory not found"
  fi
  cp -r "$chart_src/"* "$bundle_dir/chart/"
  # Remove template files from the bundle
  rm -f "$bundle_dir/chart/values.yaml.tmpl"

  # Copy tap-deploy script itself
  log_step "Package tap-deploy script"
  cp "$DEPLOY_HOME/tap-deploy" "$bundle_dir/"

  # Copy application templates
  local tmpl_src
  if [ -d "$DEPLOY_HOME/templates" ]; then
    tmpl_src="$DEPLOY_HOME/templates"
  elif [ -d "$WORK_DIR/templates" ]; then
    tmpl_src="$WORK_DIR/templates"
  else
    tmpl_src=""
  fi
  if [ -n "$tmpl_src" ]; then
    cp -r "$tmpl_src/"* "$bundle_dir/config/"
  fi

  # Generate offline deployment instructions
  cat > "$bundle_dir/README-OFFLINE.txt" <<'EOF'
=== TapData Offline Installation Bundle ===

Directory structure:
  tapdata-bundle/
  ├── tap-deploy          # Deployment script
  ├── images/             # Container images
  │   └── images.tar      # Image bundle
  ├── chart/              # Helm Chart
  └── config/             # Application configuration templates

Offline deployment steps:

1. Transfer the bundle to the target server
   scp images-bundle.tar.gz user@target-host:/opt/

2. Extract the bundle
   tar -xzf images-bundle.tar.gz

3. Load container images
   docker load -i tapdata-bundle/images/images.tar

4. Push images to internal registry (e.g. Harbor)
   docker tag tapdata8/tapdata:latest <harbor-registry>/tapdata/tapdata:latest
   docker push <harbor-registry>/tapdata/tapdata:latest
   # Repeat for other images

5. Initialize configuration
   bash tapdata-bundle/tap-deploy init

6. Execute deployment
   bash tapdata-bundle/tap-deploy apply

Notes:
- All images must be pushed to the internal registry before K8s can pull them
- Select On-Prem mode during init, and configure the internal image registry URL
EOF

  # Pack everything
  log_step "Compress bundle"
  cd "$tmp_dir"
  tar -czf "$output" tapdata-bundle/
  rm -rf "$tmp_dir"

  echo ""
  log_info "Offline installation bundle created: $output"
  echo ""
  echo "  Contents:"
  echo "    - Container images: ${images[*]}"
  echo "    - Helm Chart"
  echo "    - tap-deploy script"
  echo "    - Offline deployment instructions"
  echo ""
  echo "  Transfer to offline environment:"
  echo "    scp $output user@target-host:/opt/"
}

# ============================================================================
# Main Entry Point
# ============================================================================

usage() {
  cat <<EOF
TapData One-Deploy v${TAP_DEPLOY_VERSION}

Usage:
  bash tap-deploy <command> [options]

Commands:
  init      Initialize configuration (interactive wizard)
  plan      Preview deployment content
  apply     Execute deployment
  status    View deployment status
  destroy   Destroy deployment
  bundle    Create offline installation bundle (On-Prem scenario)

Options:
  -d, --dir <path>   Specify working directory (default: current directory)
  -h, --help         Show help information
  -v, --version      Show version information

Examples:
  bash tap-deploy init                                    # Initialize in current directory
  bash tap-deploy -d /opt/tapdata init                    # Initialize in specified directory
  bash tap-deploy plan                                    # Preview deployment
  bash tap-deploy apply                                   # Execute deployment
  bash tap-deploy status                                  # View status
  bash tap-deploy destroy                                 # Destroy deployment
  bash tap-deploy bundle --output bundle.tar.gz           # Create offline bundle

Environment Variables:
  TAP_DEPLOY_CONFIG_URL  Configuration template URL (default: https://resource.tapdata.net/deploy-config/tapdata-deploy-latest.tar.gz)

Current Worker Directory:
  ${WORK_DIR}

EOF
}

main() {
  # Parse global options first
  local opt_dir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--dir)
        opt_dir="$2"
        shift 2
        ;;
      *)
        break
        ;;
    esac
  done

  # Override WORK_DIR if -d is specified
  if [ -n "$opt_dir" ]; then
    # Convert to absolute path
    if [[ "$opt_dir" != /* ]]; then
      opt_dir="$(pwd)/$opt_dir"
    fi
    mkdir -p "$opt_dir"
    WORK_DIR="$(cd "$opt_dir" && pwd)"
    CONFIG_FILE="${WORK_DIR}/.tap-deploy.env"
  fi

  local command="${1:-}"
  shift || true

  case "$command" in
    init)
      cmd_init
      ;;
    plan)
      cmd_plan
      ;;
    apply)
      cmd_apply
      ;;
    status)
      cmd_status
      ;;
    destroy)
      cmd_destroy
      ;;
    bundle)
      local bundle_output=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --output|-o)
            bundle_output="$2"
            shift 2
            ;;
          *)
            shift
            ;;
        esac
      done
      cmd_bundle "$bundle_output"
      ;;
    -h|--help|help)
      usage
      ;;
    -v|--version)
      echo "TapData One-Deploy v${TAP_DEPLOY_VERSION}"
      echo "Platform: ${PLATFORM}/${ARCH}"
      echo "Working directory: ${WORK_DIR}"
      ;;
    "")
      usage
      exit 1
      ;;
    *)
      log_error "Unknown command: $command\nRun 'bash tap-deploy --help' for usage."
      ;;
  esac
}

main "$@"
