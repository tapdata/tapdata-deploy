# ============================================================================
# Template Download
# ============================================================================

# Download templates from remote server
# Downloads the archive to current directory, extracts into WORK_DIR/.tmp
download_templates() {
  local mode="$1"
  local target_dir="${2:-$WORK_DIR}"

  check_cmd curl
  check_cmd tar

  # Determine the local archive path (saved in current working directory)
  local archive_name
  archive_name=$(basename "$DEPLOY_CONFIG_URL")
  local archive_path="$(pwd)/${archive_name}"

  # Check if archive already exists in current directory
  if [ -f "$archive_path" ]; then
    log_info "Found existing archive: $archive_path, using it directly"
  else
    log_step "Downloading configuration templates from $DEPLOY_CONFIG_URL"
    curl -fSL -o "$archive_path" "$DEPLOY_CONFIG_URL" || {
      rm -f "$archive_path"
      log_error "Failed to download templates from $DEPLOY_CONFIG_URL"
    }
    log_info "Archive saved to: $archive_path"
  fi

  # Extract into WORK_DIR/.tmp to keep working directory clean
  local tmp_dir="${target_dir}/.tmp"
  rm -rf "$tmp_dir"
  mkdir -p "$tmp_dir"

  tar -xzf "$archive_path" -C "$tmp_dir"

  # Find the extracted directory (may be tapdata-deploy-*/ or just the content)
  local extracted_dir
  extracted_dir=$(find "$tmp_dir" -maxdepth 1 -type d -name "tapdata-deploy*" | head -1)
  if [ -z "$extracted_dir" ]; then
    extracted_dir="$tmp_dir"
  fi

  # Copy mode-specific templates
  case "$mode" in
    lite)
      cp -r "$extracted_dir/deploy-on-docker" "$target_dir/deploy-on-docker"
      cp -r "$extracted_dir/templates" "$target_dir/templates"
      ;;
    cloud)
      cp -r "$extracted_dir/infrastructure" "$target_dir/infrastructure"
      cp -r "$extracted_dir/deploy-on-kubernetes" "$target_dir/deploy-on-kubernetes"
      cp -r "$extracted_dir/templates" "$target_dir/templates"
      ;;
    on-prem)
      cp -r "$extracted_dir/deploy-on-kubernetes" "$target_dir/deploy-on-kubernetes"
      cp -r "$extracted_dir/templates" "$target_dir/templates"
      ;;
  esac

  # Clean up .tmp directory
  rm -rf "$tmp_dir"
  log_info "Templates extracted successfully"
}

# Get template source directory (downloaded during init)
get_template_dir() {
  local subdir="$1"

  if [ -d "$WORK_DIR/$subdir" ]; then
    echo "$WORK_DIR/$subdir"
  elif [ -d "$DEPLOY_HOME/$subdir" ]; then
    echo "$DEPLOY_HOME/$subdir"
  else
    log_error "Template directory not found: $subdir. Run 'tap-deploy init' first."
  fi
}

# ============================================================================
# INIT Command
# ============================================================================

cmd_init() {
  log_step "TapData One-Deploy - Initialization Wizard"
  echo ""

  # Step 0: Confirm working directory
  local confirmed_dir
  prompt_input "Working directory" "$WORK_DIR" confirmed_dir
  if [ -n "$confirmed_dir" ]; then
    # Convert to absolute path
    if [[ "$confirmed_dir" != /* ]]; then
      confirmed_dir="$(pwd)/$confirmed_dir"
    fi
    mkdir -p "$confirmed_dir"
    WORK_DIR="$(cd "$confirmed_dir" && pwd)"
    CONFIG_FILE="${WORK_DIR}/.tap-deploy.env"
  fi
  log_info "Working directory set to: $WORK_DIR"
  echo ""

  # Step 0.1: Check for existing configuration
  if [ -f "$CONFIG_FILE" ]; then
    log_warn "Existing configuration found at $CONFIG_FILE"
    if ! prompt_confirm "Clear existing configuration and re-initialize?" "n"; then
      log_info "Initialization cancelled"
      return 1
    fi
    # Clean working directory (keep downloaded archive files like .tar.gz)
    log_info "Cleaning working directory (keeping archive files)..."
    local item
    for item in "$WORK_DIR"/*; do
      case "$item" in
        *.tar.gz|*.tgz|*.zip)
          # Keep downloaded archive files
          ;;
        *)
          rm -rf "$item"
          ;;
      esac
    done
    rm -f "$WORK_DIR/.tap-deploy.env"
    log_info "Working directory cleaned"
    echo ""
  fi

  # Step 1: Select deployment mode
  prompt_select "Select deployment mode" \
    "Lite (Docker) - Development, testing, quick POC" \
    "Cloud (Terraform + Helm) - Cloud production environment" \
    "On-Prem (K8s + Helm) - Private data center / air-gapped"

  case "$SELECTED_OPTION" in
    Lite*)  TAP_DEPLOY_MODE="lite" ;;
    Cloud*) TAP_DEPLOY_MODE="cloud" ;;
    On-Prem*) TAP_DEPLOY_MODE="on-prem" ;;
  esac

  # Step 2: Common parameters
  #echo ""
  #log_step "Configure common parameters"
  #prompt_input "Admin Password" "AbcDef123" TAP_DEPLOY_ADMIN_PASSWORD
  #prompt_input "Timezone" "Asia/Shanghai" TAP_DEPLOY_TZ
  #prompt_input "JDK version (java8/java11/java17)" "java17" TAP_DEPLOY_JAVA_VERSION
  #prompt_input "License server address" "" TAP_DEPLOY_LICENSE_HOST

  # Generate UUID
  TAP_DEPLOY_UUID=$(gen_uuid)

  # Step 3: Mode-specific parameters
  echo ""
  case "$TAP_DEPLOY_MODE" in
    lite)
      _init_lite
      ;;
    cloud)
      _init_cloud
      ;;
    on-prem)
      _init_onprem
      ;;
  esac

  # Step 4: Download templates
  echo ""
  log_step "Download configuration templates"
  download_templates "$TAP_DEPLOY_MODE" "$WORK_DIR"

  # Step 5: Render templates
  echo ""
  log_step "Render configuration files"
  _render_configs

  # Step 6: Save config
  save_config

  # Step 7: Next steps
  echo ""
  log_step "Initialization complete"
  echo ""
  echo "  Next steps:"
  echo "    1. Review the generated configuration files"
  echo "    2. Run 'bash tap-deploy plan'  to preview deployment"
  echo "    3. Run 'bash tap-deploy apply'  to execute deployment"
  echo ""
}

