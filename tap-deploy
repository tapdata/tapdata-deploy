#!/bin/bash

set -euo pipefail

# ============================================================================
# TapData One-Deploy CLI
# Unified deployment script for TapData containerized deployment
# ============================================================================

# ---- Global Variables ----
WORK_DIR=$(pwd)
DEPLOY_HOME=$(cd "$(dirname "$0")" && pwd)
CONFIG_FILE="${WORK_DIR}/.tap-deploy.env"
DEPLOY_CONFIG_URL="${TAP_DEPLOY_CONFIG_URL:-https://resource.tapdata.net/deploy-config/tapdata-deploy-latest.tar.gz}"
TAP_DEPLOY_VERSION="1.0.0"

# ---- OS/Arch Detection ----
OS_NAME=$(uname -s)
ARCH_NAME=$(uname -m)

case "$OS_NAME" in
  Linux)  PLATFORM="linux" ;;
  Darwin) PLATFORM="darwin" ;;
  *)      echo "ERROR: Unsupported OS: $OS_NAME"; exit 1 ;;
esac

case "$ARCH_NAME" in
  x86_64|amd64) ARCH="amd64" ;;
  aarch64|arm64) ARCH="arm64" ;;
  *)            echo "ERROR: Unsupported architecture: $ARCH_NAME"; exit 1 ;;
esac

# ============================================================================
# Docker Registry API Functions
# ============================================================================

# Fetch tags from Docker Registry HTTP API V2
# Supports Docker Hub and other registries
fetch_image_tags() {
  local image="$1"
  local limit="${2:-5}"
  
  check_cmd curl
  check_cmd jq
  
  # Parse image name
  local registry=""
  local repo=""
  local image_name="$image"
  
  if [[ "$image" == *"/"* ]]; then
    # Check if it has a registry prefix
    local first_part
    first_part=$(echo "$image" | cut -d'/' -f1)
    if [[ "$first_part" == *.* ]]; then
      # Has registry (e.g., nexus.tapdata.net/...)
      registry="$first_part"
      repo=$(echo "$image" | cut -d'/' -f2-)
    else
      # Docker Hub (e.g., tapdata8/tapdata)
      registry="registry-1.docker.io"
      repo="$image"
    fi
  else
    # Docker Hub library image (e.g., mongo)
    registry="registry-1.docker.io"
    repo="library/$image"
  fi
  
  # Get authentication token for Docker Hub
  local auth_header=""
  if [ "$registry" = "registry-1.docker.io" ]; then
    local token_url="https://auth.docker.io/token?service=registry.docker.io&scope=repository:${repo}:pull"
    local token
    token=$(curl -s "$token_url" | jq -r '.token' 2>/dev/null)
    if [ -n "$token" ] && [ "$token" != "null" ]; then
      auth_header="Authorization: Bearer $token"
    else
      log_warn "Failed to get Docker Hub token, trying without authentication"
    fi
  fi
  
  # Fetch tags
  local tags_url="https://${registry}/v2/${repo}/tags/list?n=${limit}"
  local response
  
  if [ -n "$auth_header" ]; then
    response=$(curl -s -H "$auth_header" "$tags_url" 2>/dev/null)
  else
    response=$(curl -s "$tags_url" 2>/dev/null)
  fi
  
  # Parse and return tags
  local tags
  tags=$(echo "$response" | jq -r '.tags[]' 2>/dev/null)
  
  if [ -z "$tags" ]; then
    log_warn "Failed to fetch tags for $image"
    return 1
  fi
  
  echo "$tags"
}

# Prompt user to select an image tag
prompt_image_tag() {
  local image="$1"
  local var_name="$2"
  local default_limit="${3:-5}"
  
  log_info "Fetching available versions for $image ..."
  
  local tags
  tags=$(fetch_image_tags "$image" "$default_limit")
  
  if [ $? -ne 0 ] || [ -z "$tags" ]; then
    log_warn "Cannot fetch tags, using default: latest"
    eval "$var_name=\"latest\""
    return
  fi
  
  # Display tags as options
  local tag_array=()
  while IFS= read -r tag; do
    [ -n "$tag" ] && tag_array+=("$tag")
  done <<< "$tags"
  
  if [ ${#tag_array[@]} -eq 0 ]; then
    log_warn "No tags found, using default: latest"
    eval "$var_name=\"latest\""
    return
  fi
  
  echo ""
  printf '  Available versions for %s:\n' "$image"
  local i
  for i in "${!tag_array[@]}"; do
    printf '    %d) %s\n' $((i + 1)) "${tag_array[$i]}"
  done
  printf '    %d) Use custom version\n' $((${#tag_array[@]} + 1))
  printf '    %d) Use latest\n' $((${#tag_array[@]} + 2))
  echo ""
  
  local choice
  while true; do
    printf '  Select version [1-%d]: ' $((${#tag_array[@]} + 2))
    read -r choice
    
    if [[ "$choice" =~ ^[0-9]+$ ]]; then
      if [ "$choice" -ge 1 ] && [ "$choice" -le "${#tag_array[@]}" ]; then
        SELECTED_IMAGE_TAG="${tag_array[$((choice - 1))]}"
        return
      elif [ "$choice" -eq $(( ${#tag_array[@]} + 1 )) ]; then
        # Custom version
        local custom_tag
        prompt_input "Enter custom version" "" custom_tag
        if [ -z "$custom_tag" ]; then
          log_warn "Empty version, using latest"
          SELECTED_IMAGE_TAG="latest"
        else
          SELECTED_IMAGE_TAG="$custom_tag"
        fi
        return
      elif [ "$choice" -eq $(( ${#tag_array[@]} + 2 )) ]; then
        SELECTED_IMAGE_TAG="latest"
        return
      fi
    fi
    printf '  Invalid selection, please try again\n'
  done
}

# ============================================================================
# Utility Functions
# ============================================================================

# Cross-platform date formatting
_format_date() {
  if [ "$PLATFORM" = "darwin" ]; then
    date "$@"
  else
    date "$@"
  fi
}

# Logging
log_info() {
  local timestamp
  timestamp=$(_format_date '+%Y-%m-%d %H:%M:%S')
  printf '\033[0;32m[%s] [INFO]\033[0m %s\n' "$timestamp" "$*"
}

log_warn() {
  local timestamp
  timestamp=$(_format_date '+%Y-%m-%d %H:%M:%S')
  printf '\033[0;33m[%s] [WARN]\033[0m %s\n' "$timestamp" "$*" >&2
}

log_error() {
  local timestamp
  timestamp=$(_format_date '+%Y-%m-%d %H:%M:%S')
  printf '\033[0;31m[%s] [ERROR]\033[0m %s\n' "$timestamp" "$*" >&2
  exit 1
}

log_step() {
  printf '\n\033[0;36m==>\033[0m %s\n' "$*"
}

log_step_sub() {
  printf '  \033[0;36m-->\033[0m %s\n' "$*"
}

# Portable sed in-place editing (compatible with Linux and macOS)
sed_inplace() {
  local expr="$1"
  local file="$2"
  local tmp_file
  tmp_file=$(mktemp)
  sed -e "$expr" "$file" > "$tmp_file" && mv "$tmp_file" "$file"
}

# Check if a command exists
check_cmd() {
  if ! command -v "$1" &>/dev/null; then
    log_error "Required command '$1' not found. Please install it first."
  fi
}

# Check if a command exists (non-fatal)
has_cmd() {
  command -v "$1" &>/dev/null
}

# Generate UUID
gen_uuid() {
  if [ "$PLATFORM" = "darwin" ]; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())"
  fi
}

# Read input with prompt
prompt_input() {
  local prompt="$1"
  local default="${2:-}"
  local var_name="$3"
  local result

  if [ -n "$default" ]; then
    printf '  %s [%s]: ' "$prompt" "$default"
  else
    printf '  %s: ' "$prompt"
  fi
  read -r result

  if [ -z "$result" ]; then
    result="$default"
  fi

  eval "$var_name=\"\$result\""
}

# Read password (no echo)
prompt_password() {
  local prompt="$1"
  local var_name="$2"
  local result

  printf '  %s: ' "$prompt"
  if [ "$PLATFORM" = "darwin" ]; then
    read -rs result
  else
    read -rs result
  fi
  echo
  eval "$var_name=\"\$result\""
}

# Select from options
prompt_select() {
  local prompt="$1"
  shift
  local options=("$@")
  local i

  printf '  %s:\n' "$prompt"
  for i in "${!options[@]}"; do
    printf '    %d) %s\n' $((i + 1)) "${options[$i]}"
  done

  local choice
  while true; do
    printf '  Select [1-%d]: ' "${#options[@]}"
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#options[@]}" ]; then
      SELECTED_OPTION="${options[$((choice - 1))]}"
      return
    fi
    printf '  Invalid selection, please try again
'
  done
}

# Yes/No confirmation
prompt_confirm() {
  local prompt="$1"
  local default="${2:-n}"
  local result

  if [ "$default" = "y" ]; then
    printf '  %s [Y/n]: ' "$prompt"
  else
    printf '  %s [y/N]: ' "$prompt"
  fi
  read -r result

  case "$result" in
    y|Y|yes|YES) return 0 ;;
    n|N|no|NO)   return 1 ;;
    "")
      if [ "$default" = "y" ]; then return 0; else return 1; fi
      ;;
    *) return 1 ;;
  esac
}

# ============================================================================
# Template Rendering
# ============================================================================

# Render a template file by replacing {{VAR}} placeholders
render_template() {
  local src="$1"
  local dst="$2"

  if [ ! -f "$src" ]; then
    log_error "Template file not found: $src"
  fi

  local tmp_file
  tmp_file=$(mktemp)
  cp "$src" "$tmp_file"

  # Source config if it exists
  if [ -f "$CONFIG_FILE" ]; then
    set -a
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    set +a
  fi

  # Find all {{VAR}} patterns and replace them
  local vars
  vars=$(grep -oE '\{\{[A-Za-z_][A-Za-z0-9_]*\}\}' "$tmp_file" 2>/dev/null | sort -u | sed 's/[{}]//g' || true)

  for var in $vars; do
    local val=""
    # Use bash indirect variable expansion to get the value
    val="${!var:-}"
    # Escape special characters in val for sed replacement
    local escaped_val
    escaped_val=$(printf '%s\n' "$val" | sed 's/[&/\\]/\\&/g')
    sed_inplace "s|{{${var}}}|${escaped_val}|g" "$tmp_file"
  done

  # Ensure destination directory exists
  mkdir -p "$(dirname "$dst")"
  mv "$tmp_file" "$dst"
}

