  cp -rn "$docker_dir/mongodb/config/"* "$WORK_DIR/mongodb/config/" 2>/dev/null || true
  cp -n "$docker_dir/tapdata/docker-entrypoint.sh" "$WORK_DIR/tapdata/docker-entrypoint.sh" 2>/dev/null || true
}

_render_cloud_configs() {
  # Render Terraform tfvars
  local infra_dir
  infra_dir=$(get_template_dir "infrastructure")
  local provider="${TAP_DEPLOY_CLOUD_PROVIDER:-huaweicloud}"

  # Set Terraform template variables
  CLOUD_REGION="${TAP_DEPLOY_CLOUD_REGION:-}"
  CLOUD_ACCESS_KEY="${TAP_DEPLOY_CLOUD_ACCESS_KEY:-}"
  CLOUD_SECRET_KEY="${TAP_DEPLOY_CLOUD_SECRET_KEY:-}"

  # Convert comma-separated AZs to Terraform list format
  local azs_raw="${TAP_DEPLOY_CLOUD_AZS:-}"
  CLOUD_AZS=""
  if [ -n "$azs_raw" ]; then
    local first=true
    IFS=',' read -ra az_array <<< "$azs_raw"
    for az in "${az_array[@]}"; do
      az=$(echo "$az" | xargs) # trim whitespace
      if [ "$first" = true ]; then
        CLOUD_AZS="\"$az\""
        first=false
      else
        CLOUD_AZS="$CLOUD_AZS, \"$az\""
      fi
    done
  fi

  CLOUD_CLUSTER_NAME="${TAP_DEPLOY_CLOUD_CLUSTER_NAME:-tapdata-k8s}"
  CLOUD_NODE_COUNT="${TAP_DEPLOY_CLOUD_NODE_COUNT:-2}"
  CLOUD_KEY_PAIR_NAME="${TAP_DEPLOY_CLOUD_KEY_PAIR_NAME:-}"

  if [ "$provider" = "huaweicloud" ]; then
    CLOUD_NODE_FLAVOR="${TAP_DEPLOY_CLOUD_NODE_FLAVOR:-s6.large.2}"
    render_template "$infra_dir/huaweicloud/terraform.tfvars.tmpl" "$WORK_DIR/infrastructure/huaweicloud/terraform.tfvars"
    log_info "Generated: infrastructure/huaweicloud/terraform.tfvars"

    # Copy Terraform source files (not templates)
    mkdir -p "$WORK_DIR/infrastructure/huaweicloud"
    cp "$infra_dir/huaweicloud/"*.tf "$WORK_DIR/infrastructure/huaweicloud/" 2>/dev/null || true
  else
    CLOUD_CLUSTER_VERSION="${TAP_DEPLOY_CLOUD_CLUSTER_VERSION:-1.29}"
    CLOUD_NODE_INSTANCE_TYPE="${TAP_DEPLOY_CLOUD_NODE_INSTANCE_TYPE:-t3.medium}"
    render_template "$infra_dir/aws/terraform.tfvars.tmpl" "$WORK_DIR/infrastructure/aws/terraform.tfvars"
    log_info "Generated: infrastructure/aws/terraform.tfvars"

    mkdir -p "$WORK_DIR/infrastructure/aws"
    cp "$infra_dir/aws/"*.tf "$WORK_DIR/infrastructure/aws/" 2>/dev/null || true
  fi

  # Render Helm values
  _render_helm_values
}

_render_cloud_configs() {
  # Re-render Helm values with cloud registry info (called during apply after TF outputs are available)
  _render_helm_values
}

_render_onprem_configs() {
  _render_helm_values
}

_render_helm_values() {
  local k8s_dir
  k8s_dir=$(get_template_dir "deploy-on-kubernetes")

  # Set Helm template variables
  IMAGE_REGISTRY="${TAP_DEPLOY_IMAGE_REGISTRY:-}"
  MONGODB_USER="${TAP_DEPLOY_MONGO_USER:-root}"
  MONGODB_PASSWORD="${TAP_DEPLOY_MONGO_PASSWORD:-AbcDef123}"
  MONGODB_MEMBERS="${MONGODB_MEMBERS:-3}"
  MONGODB_STORAGE_CLASS="${MONGODB_STORAGE_CLASS:-}"
  TZ="${TAP_DEPLOY_TZ:-Asia/Shanghai}"
  LICENSE_HOST="${TAP_DEPLOY_LICENSE_HOST:-}"
  IMAGE_TAG="${IMAGE_TAG:-latest}"
  APISERVER_ENABLED="${APISERVER_ENABLED:-true}"
  INGRESS_ENABLED="${INGRESS_ENABLED:-false}"
  INGRESS_CLASS_NAME="${INGRESS_CLASS_NAME:-}"

  # Replica counts
  SERVER_REPLICA_COUNT="${SERVER_REPLICA_COUNT:-2}"
  ENGINE_REPLICA_COUNT="${ENGINE_REPLICA_COUNT:-2}"
  APISERVER_REPLICA_COUNT="${APISERVER_REPLICA_COUNT:-2}"

  # Image repositories
  local image_tag="${TAP_DEPLOY_IMAGE_TAG:-latest}"
  if [ "$TAP_DEPLOY_MODE" = "cloud" ] && [ -n "$TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL" ]; then
    # Cloud mode: use inner pull URL from Terraform outputs
    # Images were pushed with specific version tag to cloud registry
    SERVER_IMAGE_REPOSITORY="${TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL}/tapdata"
    ENGINE_IMAGE_REPOSITORY="${TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL}/tapdata"
    APISERVER_IMAGE_REPOSITORY="${TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL}/tapdata"
    KUBECTL_IMAGE_REPOSITORY="${TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL}/kubectl"
  elif [ -n "$IMAGE_REGISTRY" ]; then
    SERVER_IMAGE_REPOSITORY="${IMAGE_REGISTRY}/tapdata/tapdata"
    ENGINE_IMAGE_REPOSITORY="${IMAGE_REGISTRY}/tapdata/tapdata"
    APISERVER_IMAGE_REPOSITORY="${IMAGE_REGISTRY}/tapdata/tapdata"
    KUBECTL_IMAGE_REPOSITORY="${IMAGE_REGISTRY}/tapdata/kubectl"
  else
    SERVER_IMAGE_REPOSITORY="tapdata8/tapdata"
    ENGINE_IMAGE_REPOSITORY="tapdata8/tapdata"
    APISERVER_IMAGE_REPOSITORY="tapdata8/tapdata"
    KUBECTL_IMAGE_REPOSITORY="bitnami/kubectl"
  fi
  
  # Set IMAGE_TAG for Helm values
  IMAGE_TAG="${image_tag}"

  # Service type and NodePort
  if [ "$TAP_DEPLOY_MODE" = "cloud" ] && [ "${TAP_DEPLOY_CLOUD_PROVIDER:-}" = "huaweicloud" ]; then
    SERVER_SERVICE_TYPE="NodePort"
    SERVER_NODEPORT_CONFIG="nodePort: 30303"
    APISERVER_SERVICE_TYPE="NodePort"
    APISERVER_NODEPORT_CONFIG="nodePort: 30803"
    INGRESS_ENABLED="true"
    INGRESS_CLASS_NAME="cce"
    MONGODB_STORAGE_CLASS="ssd"
  else
    SERVER_SERVICE_TYPE="ClusterIP"
    SERVER_NODEPORT_CONFIG=""
    APISERVER_SERVICE_TYPE="ClusterIP"
    APISERVER_NODEPORT_CONFIG=""
  fi

  # MongoDB hosts
  MONGODB_HOSTS="tapdata-mongodb-0.tapdata-mongodb-svc:27017,tapdata-mongodb-1.tapdata-mongodb-svc:27017,tapdata-mongodb-2.tapdata-mongodb-svc:27017"

  # Image pull secret
  if [ "$TAP_DEPLOY_MODE" = "cloud" ] && [ -n "$TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL" ]; then
    # Cloud mode: K8s nodes in same VPC can pull from inner URL without explicit pull secret
    # for Huawei SWR; for AWS ECR, IAM roles on nodes handle auth
    IMAGE_PULL_SECRET_ENABLED="true"
    IMAGE_PULL_SECRET_REGISTRY="$TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL"
  elif [ -n "$IMAGE_REGISTRY" ]; then
    IMAGE_PULL_SECRET_ENABLED="true"
    IMAGE_PULL_SECRET_REGISTRY="$IMAGE_REGISTRY"
  else
    IMAGE_PULL_SECRET_ENABLED="false"
    IMAGE_PULL_SECRET_REGISTRY=""
  fi
  IMAGE_PULL_SECRET_USERNAME="${TAP_DEPLOY_CLOUD_ACCESS_KEY:-${IMAGE_PULL_SECRET_USERNAME:-}}"
  IMAGE_PULL_SECRET_PASSWORD="${TAP_DEPLOY_CLOUD_SECRET_KEY:-${IMAGE_PULL_SECRET_PASSWORD:-}}"

  # Application config variables
  MONGODB_CONNECTION_STRING="${MONGODB_CONNECTION_STRING:-}"
  TAPDATA_MODE="${TAPDATA_MODE:-cluster}"
  TAPDATA_BASE_URLS="${TAPDATA_BASE_URLS:-http://127.0.0.1:3030/api/}"
  TAPDATA_BACKEND_URL="${TAPDATA_BACKEND_URL:-http://127.0.0.1:3030/api/}"
  TAPDATA_UUID="${TAP_DEPLOY_UUID:-}"

  render_template "$k8s_dir/values.yaml.tmpl" "$WORK_DIR/values.yaml"
  log_info "Generated: values.yaml"

  # Copy Helm chart files
  if [ ! -d "$WORK_DIR/deploy-on-kubernetes" ]; then
    cp -r "$k8s_dir" "$WORK_DIR/deploy-on-kubernetes"
    # Remove template file from the copy
    rm -f "$WORK_DIR/deploy-on-kubernetes/values.yaml.tmpl"
  fi
}

