# Push required images to cloud image registry
# Images: tapdata (main service) and kubectl (init container)
_push_images_to_cloud_registry() {
  local push_url="$1"
  local login_command="$2"
  local provider="$3"
  local region="$4"

  check_cmd docker

  # Define image sources (primary and fallback) with version tag
  local image_tag="${TAP_DEPLOY_IMAGE_TAG:-latest}"
  local tapdata_primary="tapdata8/tapdata:${image_tag}"
  local tapdata_fallback="nexus.tapdata.net/tapdata-docker/tapdata-enterprise:${image_tag}"
  local kubectl_primary="bitnami/kubectl:latest"
  local kubectl_fallback="nexus.tapdata.net/tapdata-docker/kubectl:latest"

  # Target image names in cloud registry
  local tapdata_target="${push_url}/tapdata:${image_tag}"
  local kubectl_target="${push_url}/kubectl:latest"

  # Login to cloud registry
  log_info "Logging in to cloud image registry..."
  case "$provider" in
    huaweicloud)
      # Huawei SWR: use docker login with AK/SK temporary token
      # The login_command from TF output is for reference only; we need to execute actual login
      local swr_login_url="swr.${region}.myhuaweicloud.com"
      log_info "Login URL: $swr_login_url"
      eval "$login_command" || {
        log_error "Failed to login to Huawei SWR. Command: $login_command"
      }
      ;;
    aws)
      # AWS ECR: use aws ecr get-login-password
      eval "$login_command" || {
        log_error "Failed to login to AWS ECR. Command: $login_command"
      }
      ;;
    *)
      log_error "Unsupported cloud provider for image push: $provider"
      ;;
  esac
  log_info "Successfully logged in to cloud image registry"

  # Pull, tag, and push tapdata image
  log_info "Processing tapdata image..."
  _pull_tag_push "$tapdata_primary" "$tapdata_fallback" "$tapdata_target"

  # Pull, tag, and push kubectl image
  log_info "Processing kubectl image..."
  _pull_tag_push "$kubectl_primary" "$kubectl_fallback" "$kubectl_target"

  log_info "All images pushed to cloud registry successfully"
}

# Pull image (with fallback), tag, and push to target registry
_pull_tag_push() {
  local primary="$1"
  local fallback="$2"
  local target="$3"

  # Try pulling from primary source
  log_info "Pulling $primary ..."
  if docker pull "$primary" 2>/dev/null; then
    docker tag "$primary" "$target"
  else
    log_warn "Failed to pull $primary, trying fallback: $fallback"
    docker pull "$fallback" || {
      log_error "Failed to pull image from both primary and fallback sources: $primary / $fallback"
    }
    docker tag "$fallback" "$target"
  fi

  # Push to cloud registry
  log_info "Pushing $target ..."
  docker push "$target" || {
    log_error "Failed to push image: $target"
  }
  log_info "Pushed: $target"
}

_apply_cloud() {
  local provider="${TAP_DEPLOY_CLOUD_PROVIDER:-huaweicloud}"

  check_cmd terraform
  check_cmd helm
  check_cmd kubectl
  check_cmd docker

  # Phase 1: Terraform
  log_step "Phase 1: Create infrastructure (Terraform)"
  local tf_dir="$WORK_DIR/infrastructure/$provider"

  if [ ! -d "$tf_dir" ]; then
    # Try DEPLOY_HOME
    tf_dir="$DEPLOY_HOME/infrastructure/$provider"
    if [ ! -d "$tf_dir" ]; then
      log_error "Terraform directory not found: infrastructure/$provider"
    fi
  fi

  cd "$tf_dir"
  terraform init
  terraform apply -var-file=terraform.tfvars -auto-approve

  # Phase 2: Configure kubeconfig
  log_step "Phase 2: Configure Kubeconfig"
  mkdir -p ~/.kube
  terraform output -raw kubeconfig > ~/.kube/config-tapdata
  export KUBECONFIG=~/.kube/config-tapdata

  # Phase 3: Get registry info from Terraform outputs
  log_step "Phase 3: Retrieve image registry information"
  local registry_external_push_url
  registry_external_push_url=$(terraform output -raw registry_external_push_url)
  local registry_inner_pull_url
  registry_inner_pull_url=$(terraform output -raw registry_inner_pull_url)
  local registry_login_command
  registry_login_command=$(terraform output -raw registry_login_command)
  local registry_auth_info
  registry_auth_info=$(terraform output -json registry_auth_info)

  # Parse auth info (extract fields from JSON)
  local registry_org registry_repo registry_region registry_provider
  if command -v python3 &>/dev/null; then
    registry_org=$(echo "$registry_auth_info" | python3 -c "import sys,json; print(json.load(sys.stdin)['organization'])" 2>/dev/null || echo "")
    registry_repo=$(echo "$registry_auth_info" | python3 -c "import sys,json; print(json.load(sys.stdin)['repository'])" 2>/dev/null || echo "")
    registry_region=$(echo "$registry_auth_info" | python3 -c "import sys,json; print(json.load(sys.stdin)['region'])" 2>/dev/null || echo "")
    registry_provider=$(echo "$registry_auth_info" | python3 -c "import sys,json; print(json.load(sys.stdin)['provider'])" 2>/dev/null || echo "")
  elif command -v jq &>/dev/null; then
    registry_org=$(echo "$registry_auth_info" | jq -r '.organization' 2>/dev/null || echo "")
    registry_repo=$(echo "$registry_auth_info" | jq -r '.repository' 2>/dev/null || echo "")
    registry_region=$(echo "$registry_auth_info" | jq -r '.region' 2>/dev/null || echo "")
    registry_provider=$(echo "$registry_auth_info" | jq -r '.provider' 2>/dev/null || echo "")
  else
    log_error "python3 or jq is required to parse Terraform output. Please install one of them."
  fi

  log_info "Registry inner pull URL:  $registry_inner_pull_url"
  log_info "Registry external push URL: $registry_external_push_url"
  log_info "Registry organization: $registry_org"
  log_info "Registry repository: $registry_repo"

  # Save registry info to config for later use
  TAP_DEPLOY_CLOUD_REGISTRY_INNER_PULL_URL="$registry_inner_pull_url"
  TAP_DEPLOY_CLOUD_REGISTRY_EXTERNAL_PUSH_URL="$registry_external_push_url"
  TAP_DEPLOY_CLOUD_REGISTRY_ORG="$registry_org"
  TAP_DEPLOY_CLOUD_REGISTRY_REPO="$registry_repo"
  TAP_DEPLOY_CLOUD_REGISTRY_REGION="$registry_region"
  TAP_DEPLOY_CLOUD_REGISTRY_PROVIDER="$registry_provider"

  # Phase 4: Push images to cloud registry
  log_step "Phase 4: Push images to cloud registry"
  _push_images_to_cloud_registry "$registry_external_push_url" "$registry_login_command" "$provider" "$registry_region"

  # Set image registry for Helm values rendering (use inner pull URL for K8s pods)
  TAP_DEPLOY_IMAGE_REGISTRY="$registry_inner_pull_url"

  # Phase 5: Install MongoDB Operator
  log_step "Phase 5: Install MongoDB Community Operator"
  helm repo add mongodb https://mongodb.github.io/helm-charts
  helm repo update
  helm install community-operator mongodb/community-operator \
    --namespace mongodb \
    --create-namespace \
    --set operator.watchNamespace="*"

  # Wait for operator to be ready
  log_info "Waiting for MongoDB Operator to be ready..."
  kubectl wait --for=condition=ready pod -l app.kubernetes.io/name=mongodb-community-operator -n mongodb --timeout=120s || true

  # Phase 6: Re-render Helm values with cloud registry info and deploy
  log_step "Phase 6: Deploy TapData (Helm)"
  cd "$WORK_DIR"
  _render_cloud_configs
  _helm_install

  echo ""
  log_info "TapData Cloud deployment initiated!"
  echo ""
  echo "  Check deployment status: bash tap-deploy status"
  echo "  Get access address:      kubectl -n ${TAP_DEPLOY_NAMESPACE:-tapdata} describe ingress tapdata-ingress | grep 'kubernetes.io/elb.ip'"
}

_apply_onprem() {
  check_cmd helm
